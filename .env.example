# Nebius Token Factory
NEBIUS_TOKEN_FACTORY_API_KEY=
NEBIUS_TOKEN_FACTORY_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_TOKEN_FACTORY_TEXT_MODEL=moonshotai/Kimi-K2.5
NEBIUS_TOKEN_FACTORY_MODEL=moonshotai/Kimi-K2.5
NEBIUS_TOKEN_FACTORY_MODEL_FAST=moonshotai/Kimi-K2.5-fast
NEBIUS_TOKEN_FACTORY_CONSOLE_URL=https://tokenfactory.nebius.com/
NEBIUS_TOKEN_FACTORY_DOCS_URL=https://docs.tokenfactory.nebius.com/quickstart

# Nebius Cloud
NEBIUS_CLOUD_API_ENDPOINT=api.nebius.cloud
NEBIUS_CLOUD_FEDERATION_ENDPOINT=auth.nebius.com
NEBIUS_CLOUD_TENANT_ID=tenant-xxxxxxxxxxxxxxxxxx
NEBIUS_CLOUD_PROJECT_ID=project-xxxxxxxxxxxxxxxxxx
NEBIUS_CLOUD_PROJECT_NAME=
NEBIUS_CLOUD_REGION=eu-north1
NEBIUS_CLOUD_PROFILE=rocdbot
NEBIUS_CLOUD_PUBLIC_KEY_ID=
# Fill these only if you want service-account auth instead of CLI federation.
NEBIUS_CLOUD_SERVICE_ACCOUNT_ID=
NEBIUS_CLOUD_PRIVATE_KEY_PATH=
NEBIUS_CLOUD_CONSOLE_URL=https://console.nebius.com/
